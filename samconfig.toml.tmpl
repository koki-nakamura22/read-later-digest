version = 0.1

# ------------------------------------------------------------
# samconfig.toml.tmpl
#
# このファイルをコピーして `samconfig.toml` を作成し、
# 自身の環境に合わせて値を編集してください:
#     cp samconfig.toml.tmpl samconfig.toml
#
# 役割:
#   - `sam build` / `sam deploy` の標準設定 (parameter_overrides 等)
#   - ローカル実行 (`uv run`) 用の環境変数の単一の出所(下記 [local])
#
# `samconfig.toml` 自体は .gitignore 済み。機密値も当面ここに置く
# (個人利用のため)。値変更後は以下で `.env` を再生成:
#     uv run python scripts/gen-env.py
#
# TODO: リポジトリ共有 / CI 導入 / prod 環境分離のいずれかが
#       発生したタイミングで、機密値を AWS Secrets Manager
#       (template.yaml の SECRETS_PREFIX 経由) に移行する。
# ------------------------------------------------------------

[default.global.parameters]
stack_name = "read-later-digest"
region = "ap-northeast-1"

[default.build.parameters]
cached = true
parallel = true

[default.deploy.parameters]
capabilities = "CAPABILITY_IAM"
confirm_changeset = true
resolve_s3 = true
# template.yaml の Parameters と対応 (PascalCase)。
# scripts/gen-env.py が UPPER_SNAKE に変換して .env にも展開する。
parameter_overrides = [
    "NotionDbId=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx",
    "NotionStatusUnread=未読",
    "NotionStatusProcessed=処理済み",
    "MailFrom=digest@example.com",
    "MailTo=me@example.com",
]

# ------------------------------------------------------------
# [local] — `uv run` でのローカル実行用 env (Lambda へは流れない)
#
# scripts/gen-env.py が以下の2系統を統合して `.env` を生成する:
#   1. 上記 [default.deploy.parameters].parameter_overrides
#      (PascalCase → UPPER_SNAKE に変換)
#   2. 下記 [local] の値 (UPPER_SNAKE のまま)
#
# 機密 (NOTION_TOKEN / ANTHROPIC_API_KEY / SLACK_WEBHOOK_URL) は
# ここに記載する。Lambda 実行時はこれらが Secrets Manager / SSM
# 経由で注入される想定 (template.yaml: SECRETS_PREFIX 参照)。
# ------------------------------------------------------------
[local]
NOTION_TOKEN = "secret_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx"
ANTHROPIC_API_KEY = "sk-ant-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx"
AWS_REGION = "ap-northeast-1"
NOTIFY_CHANNELS = "mail"

# Slack 通知を有効にする場合 (NOTIFY_CHANNELS に "slack" を含めた時)
# SLACK_WEBHOOK_URL = "https://hooks.slack.com/services/xxx/yyy/zzz"
# SLACK_TIMEOUT_SEC = "10.0"

# 任意の上書き (デフォルト値は src/read_later_digest/config.py 参照)
# LLM_MODEL = "claude-sonnet-4-6"
# LLM_CONCURRENCY = "5"
# LLM_BODY_MAX_CHARS = "30000"
# LLM_MAX_RATE_LIMIT_RETRIES = "3"
# LLM_INITIAL_BACKOFF_SEC = "1.0"
# FETCH_TIMEOUT_SEC = "15.0"
# NOTION_STATUS_PROPERTY = "Status"
# NOTION_TYPE_PROPERTY = "Type"
# NOTION_PRIORITY_PROPERTY = "Priority"
