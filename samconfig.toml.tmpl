version = 0.1

# ------------------------------------------------------------
# samconfig.toml.tmpl
#
# このファイルをコピーして `samconfig.toml` を作成し、
# 自身の環境に合わせて値を編集してください:
#     cp samconfig.toml.tmpl samconfig.toml
#
# 役割: ローカル (`uv run`) と AWS Lambda の両方が参照する
#       「環境変数の単一の出所 (single source of truth)」。
#
# 構成:
#   - [default.deploy.parameters].parameter_overrides
#       Lambda へ渡す全 env の SoT。template.yaml の Parameters と
#       PascalCase で対応する。機密値 (NotionToken / AnthropicApiKey /
#       SlackWebhookUrl) もここに直書きする。template.yaml 側で
#       NoEcho: true 指定のため、CloudFormation コンソールや
#       describe-stacks 出力ではマスクされる。
#       sam deploy では CloudFormation 経由で Lambda env として注入され、
#       ローカルでは scripts/gen-env.py が UPPER_SNAKE に変換して
#       .env に展開する (両環境で同じ env キー名・意味になる)。
#   - [local]
#       Lambda へは流れない、ローカル限定の値のみ。
#       Lambda runtime がビルトインで提供する AWS_REGION や、
#       開発時のみ使う任意上書きを置く。
#
# `samconfig.toml` 自体は .gitignore 済み。値変更後は以下で `.env` を再生成:
#     uv run python scripts/gen-env.py
# ------------------------------------------------------------

[default.global.parameters]
stack_name = "read-later-digest"
region = "ap-northeast-1"

[default.build.parameters]
cached = true
parallel = true

[default.deploy.parameters]
capabilities = "CAPABILITY_IAM"
confirm_changeset = true
resolve_s3 = true
# template.yaml の Parameters と対応 (PascalCase)。
# scripts/gen-env.py が UPPER_SNAKE に変換して .env にも展開する。
# ここの値が「ローカル + Lambda」両方の env の SoT。
# 機密値 (NotionToken / AnthropicApiKey / SlackWebhookUrl) は
# template.yaml で NoEcho: true なので CFn 側ではマスクされる。
parameter_overrides = [
    "NotionDbId=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx",
    "NotionToken=secret_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx",
    "AnthropicApiKey=sk-ant-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx",
    # Slack 通知を使わないなら空のままでよい (NotifyChannels に "slack" を含めない限り未使用)。
    "SlackWebhookUrl=",
    "NotionStatusUnread=未読",
    "NotionStatusProcessed=処理済み",
    "MailFrom=digest@example.com",
    "MailTo=me@example.com",
    "NotifyChannels=mail",
    "NotifyGranularityMail=digest",
    "NotifyGranularitySlack=digest",
    "NotionStatusProperty=Status",
    "NotionTypeProperty=Type",
    "NotionPriorityProperty=Priority",
    "LlmModel=claude-sonnet-4-6",
    "LlmConcurrency=5",
    "LlmBodyMaxChars=30000",
    "LlmMaxRateLimitRetries=3",
    "LlmInitialBackoffSec=1.0",
    "FetchTimeoutSec=15.0",
    "SlackTimeoutSec=10.0",
]

# ------------------------------------------------------------
# [local] — ローカル限定の env (Lambda の Environment.Variables には載らない)
#
# AWS_REGION: Lambda runtime はこの値をビルトインで提供するため、
#   template.yaml の Environment.Variables には宣言しない。
#   ローカル (uv run / boto3 クライアント生成時) では明示が必要なのでここに置く。
#
# 機密値 (NOTION_TOKEN / ANTHROPIC_API_KEY / SLACK_WEBHOOK_URL) は
# parameter_overrides 側へ移動した。Lambda にも同じ値が CloudFormation
# Parameter 経由で流れる。
# ------------------------------------------------------------
[local]
AWS_REGION = "ap-northeast-1"
